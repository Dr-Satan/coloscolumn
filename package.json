{
  "name": "coloscolumn",
  "version": "0.1.0",
  "description": "A button to rule them all!",
  "license": "MIT",
  "author": "Pontoizeau Erwan",
  "type": "module",
  "main": "./dist/coloscolumn.umd.cjs",
  "module": "./dist/coloscolumn.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/coloscolumn.js",
      "require": "./dist/coloscolumn.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
